{
  "productName": "riin",
  "version": "0.1.4",
  "identifier": "com.riin.app",
  "build": {
    "beforeDevCommand": "bun run download:binaries && bun run ui:dev",
    "beforeBuildCommand": "bun run download:binaries && bun run ui:build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "resources": ["resources/config.default.yml"],
    "externalBin": ["binaries/riin-proxy"]
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 800,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 20, "y": 30 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:",
      "capabilities": ["default"]
    }
  }
}
